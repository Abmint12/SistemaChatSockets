# Copia este archivo como .env y ajusta los valores.
# Clave secreta para firmar los tokens JWT (usa una cadena larga y aleatoria).
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
# Minutos de validez del token (720 = 12 horas).
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Base de datos. Por defecto SQLite. Para Postgres:
# DATABASE_URL=postgresql://usuario:password@host:5432/basedatos
# DATABASE_URL=sqlite:///./chat.db
